---
import { icons } from "./icons";

interface Props {
  name: string;
  class?: string;
  strokeWidth?: number;
}

const { name, class: className, strokeWidth = 2 } = Astro.props;
const nodes = icons[name];
if (!nodes) {
  throw new Error(`Unknown icon: ${name}`);
}
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {
    nodes.map(([tag, attrs]) => {
      const Tag = tag;
      return <Tag {...attrs} />;
    })
  }
</svg>
