---
import Icon from "./Icon.astro";

interface Props {
  size?: "sm" | "md" | "lg";
}

// sm = footer/mobile (24px), md = nav (28px), lg = hero/404 (40px)
const { size = "md" } = Astro.props;
const box = { sm: "h-6 w-6", md: "h-7 w-7", lg: "h-10 w-10" }[size];
const icon = { sm: "h-3.5 w-3.5", md: "h-4 w-4", lg: "h-5 w-5" }[size];
---

<div class={`flex items-center justify-center rounded-md bg-primary/15 ${box}`}>
  <Icon name="shield-check" class={`text-primary ${icon}`} />
</div>
