---
import { GITHUB_URL } from "../config";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
---

<div class="flex flex-col items-center gap-5 text-center">
  <h2 class="font-primary text-xl font-bold text-foreground md:text-[22px]">
    Ready to try it in your own cluster?
  </h2>
  <div class="flex w-full flex-col gap-3 sm:w-auto sm:flex-row sm:gap-4">
    <Button variant="primary" size="lg" href={GITHUB_URL}>
      <Icon name="github" class="h-5 w-5 md:h-6 md:w-6" />
      GitHub
    </Button>
    <Button variant="outline" size="lg" disabled>
      <Icon name="play" class="h-5 w-5 md:h-6 md:w-6" />
      Demo
    </Button>
  </div>
</div>
