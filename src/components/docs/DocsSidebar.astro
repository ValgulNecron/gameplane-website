---
import Icon from "../Icon.astro";
import LogoMark from "../LogoMark.astro";
import { withBase } from "../../lib/url";

interface Props {
  /** Doc id of the current page ("" on the docs home). */
  activeId?: string;
  /** Render without the logo/back header (mobile disclosure panel). */
  bare?: boolean;
}

const { activeId = "", bare = false } = Astro.props;

interface NavLink {
  label: string;
  icon: string;
  href?: string;
  activeIds?: string[];
}

const navSections: { label: string; links: NavLink[] }[] = [
  {
    label: "START HERE",
    links: [
      { label: "Overview", icon: "layout-dashboard", href: withBase("/docs/"), activeIds: ["overview"] },
      { label: "Getting Started", icon: "rocket", href: withBase("/docs/getting-started/"), activeIds: ["getting-started"] },
    ],
  },
  {
    label: "CORE CONCEPTS",
    links: [
      { label: "Architecture", icon: "network", href: withBase("/docs/architecture/"), activeIds: ["architecture"] },
      { label: "Security", icon: "shield-check", href: withBase("/docs/security/"), activeIds: ["security"] },
    ],
  },
  {
    label: "OPERATE",
    links: [
      { label: "Servers & Config", icon: "server" },
      { label: "Console & Logs", icon: "terminal" },
      { label: "Files & Backups", icon: "folder-archive" },
      { label: "Network & Automation", icon: "workflow" },
    ],
  },
  {
    label: "PLATFORM",
    links: [
      { label: "Cluster & Storage", icon: "boxes" },
      { label: "Users & Access", icon: "users" },
      { label: "Audit & Observability", icon: "activity" },
    ],
  },
  {
    label: "DEVELOP",
    links: [
      { label: "Modules & Sources", icon: "package-plus", href: withBase("/docs/module-authoring/"), activeIds: ["module-authoring"] },
      { label: "API & Reference", icon: "braces" },
      { label: "Local Development", icon: "laptop", href: withBase("/docs/contributing/"), activeIds: ["contributing"] },
      { label: "Component Guides", icon: "blocks" },
      { label: "Testing & Release", icon: "flask-conical" },
    ],
  },
  {
    label: "REFERENCE",
    links: [
      { label: "Upgrades", icon: "history" },
      { label: "Troubleshooting", icon: "life-buoy" },
      { label: "FAQ", icon: "info", href: withBase("/docs/faq/"), activeIds: ["faq"] },
      { label: "Releases & Roadmap", icon: "milestone", href: withBase("/docs/roadmap/"), activeIds: ["roadmap", "changelog"] },
      { label: "Community", icon: "heart-handshake", href: withBase("/docs/get-involved/"), activeIds: ["get-involved"] },
    ],
  },
];
---

<div class="flex flex-col">
  {
    !bare && (
      <div class="flex flex-col gap-4 border-b border-border p-6">
        <a class="flex items-center gap-2.5" href={withBase("/docs/")}>
          <LogoMark size="md" />
          <span class="font-primary text-base font-semibold text-foreground">gameplane</span>
        </a>
        <a
          class="flex items-center gap-1.5 text-[13px] text-muted-foreground hover:text-foreground"
          href={withBase("/")}
        >
          <Icon name="arrow-left" class="h-3.5 w-3.5" />
          Back to site
        </a>
      </div>
    )
  }
  <nav class="flex flex-col gap-px px-[14px] py-2">
    {
      navSections.map((section) => {
        return (
          <>
            <span class="px-2 pb-px pt-2.5 font-primary text-[9px] font-semibold tracking-[0.7px] text-muted-foreground/70">
              {section.label}
            </span>
            {section.links.map((link) => {
              const active = link.activeIds?.includes(activeId) ?? false;
              const className = `flex h-[27px] items-center gap-2 rounded-md px-[9px] text-[11.5px] ${
                active
                  ? "bg-secondary font-medium text-foreground"
                  : "text-muted-foreground"
              }`;
              const content = (
                <>
                  <Icon name={link.icon} class={`h-3.5 w-3.5 shrink-0 ${active ? "text-primary" : "text-muted-foreground"}`} />
                  {link.label}
                </>
              );
              return link.href ? (
                <a class={`${className} hover:bg-secondary/60 hover:text-foreground`} href={link.href} aria-current={active ? "page" : undefined}>
                  {content}
                </a>
              ) : (
                <span class={className} aria-disabled="true">{content}</span>
              );
            })}
          </>
        );
      })
    }
  </nav>
</div>
