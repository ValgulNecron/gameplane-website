---
import Icon from "../Icon.astro";
import LogoMark from "../LogoMark.astro";
import { getOrderedDocs, docHref, sidebarLabel, SECTIONS } from "../../lib/docs-nav";
import { withBase } from "../../lib/url";

interface Props {
  /** Doc id of the current page ("" on the docs home). */
  activeId?: string;
  /** Render without the logo/back header (mobile disclosure panel). */
  bare?: boolean;
}

const { activeId = "", bare = false } = Astro.props;
const docs = await getOrderedDocs();
const overviewActive = activeId === "overview";
---

<div class="flex flex-col">
  {
    !bare && (
      <div class="flex flex-col gap-4 border-b border-sidebar-border p-6">
        <a class="flex items-center gap-2.5" href={withBase("/docs/")}>
          <LogoMark size="sm" />
          <span class="font-primary text-base font-semibold text-foreground">gameplane</span>
        </a>
        <a
          class="flex items-center gap-1.5 text-[13px] text-muted-foreground hover:text-foreground"
          href={withBase("/")}
        >
          <Icon name="arrow-left" class="h-3.5 w-3.5" />
          Back to site
        </a>
      </div>
    )
  }
  <nav class="flex flex-col gap-1 p-4">
    {
      SECTIONS.map((section) => {
        const sectionDocs = docs.filter((doc) => doc.data.section === section.id);
        if (sectionDocs.length === 0) return null;
        return (
          <>
            <span class="px-4 pb-1 pt-4 font-primary text-xs text-sidebar-foreground/70">
              {section.label}
            </span>
            {
              section.id === "start-here" && (
                <a
                  class={`flex items-center gap-3 rounded-pill px-4 py-2.5 text-[15px] ${
                    overviewActive
                      ? "bg-sidebar-accent text-sidebar-accent-foreground"
                      : "text-sidebar-foreground/80 hover:bg-sidebar-accent/50 hover:text-sidebar-accent-foreground"
                  }`}
                  href={withBase("/docs/")}
                  aria-current={overviewActive ? "page" : undefined}
                >
                  <Icon name="layout-dashboard" class="h-[18px] w-[18px] shrink-0" />
                  Overview
                </a>
              )
            }
            {sectionDocs.map((doc) => {
              const active = doc.id === activeId;
              return (
                <a
                  class={`flex items-center gap-3 rounded-pill px-4 py-2.5 text-[15px] ${
                    active
                      ? "bg-sidebar-accent text-sidebar-accent-foreground"
                      : "text-sidebar-foreground/80 hover:bg-sidebar-accent/50 hover:text-sidebar-accent-foreground"
                  }`}
                  href={docHref(doc)}
                  aria-current={active ? "page" : undefined}
                >
                  <Icon name={doc.data.icon} class="h-[18px] w-[18px] shrink-0" />
                  {sidebarLabel(doc)}
                </a>
              );
            })}
          </>
        );
      })
    }
  </nav>
</div>
