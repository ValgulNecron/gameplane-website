---
import Icon from "../Icon.astro";

interface Props {
  nodes: { icon: string; title: string; subtitle: string }[];
  caption?: string;
}

const { nodes, caption } = Astro.props;
---

<div class="flex flex-col items-center gap-3 py-4">
  <div class="flex w-full flex-col items-stretch gap-1 overflow-x-auto md:flex-row md:items-center">
    {
      nodes.map((node, index) => (
        <>
          {index > 0 && (
            <div class="flex items-center justify-center py-1 md:w-6 md:py-0">
              <Icon
                name="arrow-right"
                class="h-4 w-4 rotate-90 text-muted-foreground md:rotate-0"
              />
            </div>
          )}
          <div class="flex min-w-0 flex-1 flex-col items-center gap-2 rounded-m border border-border bg-card p-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-[10px] bg-secondary">
              <Icon name={node.icon} class="h-5 w-5 text-primary" />
            </div>
            <span class="text-center font-primary text-[13px] font-semibold text-foreground">
              {node.title}
            </span>
            <span class="text-center text-[11px] text-muted-foreground">{node.subtitle}</span>
          </div>
        </>
      ))
    }
  </div>
  {caption && <p class="max-w-[820px] text-center text-xs text-muted-foreground">{caption}</p>}
</div>
