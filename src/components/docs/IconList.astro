---
import Icon from "../Icon.astro";

interface Props {
  title: string;
  icon: string;
  /** Tailwind text color class for the icon. */
  iconClass?: string;
  items: string[];
}

const { title, icon, iconClass = "text-muted-foreground", items } = Astro.props;
---

<div class="flex flex-col gap-2.5">
  <span class="font-primary text-sm font-semibold text-foreground">{title}</span>
  {
    items.map((item) => (
      <div class="flex gap-2.5">
        <Icon name={icon} class={`mt-0.5 h-3.5 w-3.5 shrink-0 ${iconClass}`} />
        <span class="text-[13px] leading-normal text-muted-foreground">{item}</span>
      </div>
    ))
  }
</div>
