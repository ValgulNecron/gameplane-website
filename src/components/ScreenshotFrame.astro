---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Icon from "./Icon.astro";

interface Props {
  /** Address shown in the browser chrome bar. */
  address?: string;
  /** Dashboard screenshot; omit to render the designed placeholder. */
  src?: ImageMetadata;
  alt?: string;
  /** Placeholder caption when no screenshot is available yet. */
  placeholder?: string;
  /** Set on the above-the-fold hero image only. */
  eager?: boolean;
  class?: string;
}

const {
  address = "app.gameplane.dev",
  src,
  alt = "",
  placeholder = "Dashboard preview",
  eager = false,
  class: className = "",
} = Astro.props;
---

<div
  class={`flex flex-col overflow-hidden rounded-m border border-border bg-card shadow-lg shadow-black/20 ${className}`}
>
  <div class="flex h-10 shrink-0 items-center gap-2 border-b border-border px-4">
    <div class="flex items-center gap-1.5">
      <span class="h-2 w-2 rounded-pill bg-secondary"></span>
      <span class="h-2 w-2 rounded-pill bg-secondary"></span>
      <span class="h-2 w-2 rounded-pill bg-secondary"></span>
    </div>
    <span class="mx-auto text-xs text-muted-foreground">{address}</span>
  </div>
  {
    src ? (
      <Image
        src={src}
        alt={alt}
        widths={[640, 1280, 1920]}
        sizes="(max-width: 768px) 100vw, 1100px"
        loading={eager ? "eager" : "lazy"}
        fetchpriority={eager ? "high" : "auto"}
        class="w-full"
      />
    ) : (
      <div class="flex min-h-48 flex-1 flex-col items-center justify-center gap-3 bg-background py-16">
        <Icon name="layout-dashboard" class="h-10 w-10 text-muted-foreground" />
        <span class="text-[13px] text-muted-foreground">{placeholder}</span>
      </div>
    )
  }
</div>
