---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Icon from "./Icon.astro";

interface Props {
  /** Address shown in the browser chrome bar. */
  address?: string;
  /** Dashboard screenshot; omit to render the designed placeholder. */
  src?: ImageMetadata;
  alt?: string;
  /** Placeholder caption / icon when no screenshot is available yet. */
  placeholder?: string;
  placeholderIcon?: string;
  /** Compact chrome (showcase cards) vs the full-size hero chrome. */
  compact?: boolean;
  /** Set on the above-the-fold hero image only. */
  eager?: boolean;
  class?: string;
}

const {
  address = "app.gameplane.dev",
  src,
  alt = "",
  placeholder = "Dashboard preview",
  placeholderIcon = "layout-dashboard",
  compact = false,
  eager = false,
  class: className = "",
} = Astro.props;

const barClasses = compact ? "h-8 px-3 gap-1.5" : "h-10 px-4 gap-2";
const addressClasses = compact ? "text-[11px]" : "text-xs";
---

<div
  class={`flex flex-col overflow-hidden rounded-m border border-border bg-card shadow-lg shadow-black/20 ${className}`}
>
  <div class={`flex shrink-0 items-center border-b border-border ${barClasses}`}>
    <div class="flex items-center gap-1">
      <span class="h-1.5 w-1.5 rounded-pill bg-border"></span>
      <span class="h-1.5 w-1.5 rounded-pill bg-border"></span>
      <span class="h-1.5 w-1.5 rounded-pill bg-border"></span>
    </div>
    <span class={`mx-auto text-muted-foreground ${addressClasses}`}>{address}</span>
  </div>
  {
    src ? (
      <Image
        src={src}
        alt={alt}
        widths={[640, 1280, 1920]}
        sizes="(max-width: 768px) 100vw, 1100px"
        loading={eager ? "eager" : "lazy"}
        fetchpriority={eager ? "high" : "auto"}
        class="w-full"
      />
    ) : (
      <div
        class={`flex flex-1 flex-col items-center justify-center gap-3 bg-background ${compact ? "min-h-32 py-10" : "min-h-48 py-16"}`}
      >
        <Icon
          name={placeholderIcon}
          class={`text-muted-foreground ${compact ? "h-8 w-8" : "h-10 w-10"}`}
        />
        {!compact && <span class="text-[13px] text-muted-foreground">{placeholder}</span>}
      </div>
    )
  }
</div>
