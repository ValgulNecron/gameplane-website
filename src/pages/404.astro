---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import { withBase } from "../lib/url";
---

<MarketingLayout
  title="Page not found — Gameplane"
  description="This page doesn't exist. Check the docs or head back to the Gameplane homepage."
>
  <section class="flex flex-col items-center gap-5 px-6 pb-32 pt-24 md:pb-40 md:pt-36">
    <span class="font-primary text-7xl font-bold tracking-wide text-secondary-foreground md:text-8xl"
      >404</span
    >
    <h1 class="text-center font-primary text-2xl font-bold text-foreground md:text-[26px]">
      This page doesn't exist
    </h1>
    <p class="max-w-[520px] text-center text-[15px] text-muted-foreground">
      The page you're looking for may have been moved or renamed. Check the docs or head back to
      the homepage.
    </p>
    <div class="mt-3 flex w-full flex-col gap-3 sm:w-auto sm:flex-row sm:gap-4">
      <Button variant="primary" size="lg" href={withBase("/")}>
        <Icon name="home" class="h-5 w-5" />
        Back to home
      </Button>
      <Button variant="outline" size="lg" href={withBase("/docs/")}>
        <Icon name="book-open" class="h-5 w-5" />
        Browse docs
      </Button>
    </div>
  </section>
</MarketingLayout>
