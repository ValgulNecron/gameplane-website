---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import Badge from "../components/Badge.astro";
import CtaSection from "../components/CtaSection.astro";
import Icon from "../components/Icon.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { withBase } from "../lib/url";

const games = [
  {
    icon: "box",
    version: "v2.8.1",
    title: "Minecraft (Java Edition)",
    blurb: "Vanilla, Paper, Fabric, Forge & more with a version+loader picker and Modrinth browse.",
  },
  {
    icon: "sword",
    version: "v2.3.3",
    title: "Valheim (Dedicated)",
    blurb: "Stable/public-test channels, BepInEx mods, in-app Thunderstore browse.",
  },
  {
    icon: "pickaxe",
    version: "v2.2.0",
    title: "Terraria",
    blurb: "Vanilla + tModLoader with a version picker and a ModPacks volume.",
  },
  {
    icon: "cpu",
    version: "v1.1.2",
    title: "Factorio (Headless)",
    blurb: "Channel picker, wizard-managed settings, in-app mod-portal browse.",
  },
  {
    icon: "swords",
    version: "v1.2.0",
    title: "Palworld (Dedicated)",
    blurb: "REST-API console, save-aware graceful stop, .pak mod volume.",
  },
  {
    icon: "axe",
    version: "v1.1.0",
    title: "Rust",
    blurb: "WebRcon console, Oxide plugin volume, save-then-quit stop.",
  },
  {
    icon: "bug",
    version: "v1.1.1",
    title: "DayZ",
    blurb: "BattlEye RCon console with SIGTERM-safe restarts.",
  },
  {
    icon: "package",
    version: "v1.1.1",
    title: "Satisfactory (Dedicated)",
    blurb: "Stable/experimental branches; installs via steamcmd on first boot.",
  },
  {
    icon: "gamepad-2",
    version: "v1.1.0",
    title: "Counter-Strike 2",
    blurb: "Source RCON with a Metamod/CS# plugins volume.",
  },
  {
    icon: "bug",
    version: "v1.0.8",
    title: "ARK: Survival Ascended",
    blurb: "RCON console/moderation; CurseForge mods via -mods=.",
  },
  {
    icon: "bug",
    version: "v1.0.5",
    title: "Project Zomboid",
    blurb: "RCON console/moderation, Steam Workshop mods.",
  },
  {
    icon: "bug",
    version: "v2.0.4",
    title: "7 Days to Die",
    blurb: "Telnet console, persistent world saves, mod installers.",
  },
  {
    icon: "gamepad-2",
    version: "v2.0.2",
    title: "Garry's Mod",
    blurb: "Workshop addon collections via launch args.",
  },
  {
    icon: "box",
    version: "v1.0.2",
    title: "Enshrouded",
    blurb: "Dedicated survival server, env-configured.",
  },
  {
    icon: "box",
    version: "v1.1.0",
    title: "Don't Starve Together",
    blurb: "Dedicated co-op survival server.",
  },
  {
    icon: "sword",
    version: "v1.0.2",
    title: "V Rising",
    blurb: "Source RCON with a safe shutdown sequence.",
  },
];
---

<MarketingLayout
  title="Supported games — Gameplane"
  description="Sixteen game servers ship out of the box as versioned OCI modules, and the open template format lets you bring any containerized game."
>
  <section
    class="flex flex-col items-center gap-8 px-6 pb-16 pt-12 md:gap-12 md:px-20 md:pb-24 md:pt-20"
  >
    <SectionHeader
      eyebrow="SUPPORTED GAMES"
      title="Deploy the games your community plays"
      subtitle="Sixteen game servers ship out of the box — and the module format is open, so more are just a template away."
    />

    <div class="grid w-full max-w-[1280px] grid-cols-1 gap-4 md:grid-cols-3 md:gap-6">
      {
        games.map((game) => (
          <div class="flex flex-col gap-4 rounded-m border border-border bg-card p-6">
            <div class="flex items-center justify-between">
              <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-secondary">
                <Icon name={game.icon} class="h-[26px] w-[26px] text-primary" />
              </div>
              <Badge>{game.version}</Badge>
            </div>
            <h2 class="font-primary text-lg font-semibold text-foreground">{game.title}</h2>
            <p class="text-[13px] leading-normal text-muted-foreground">{game.blurb}</p>
          </div>
        ))
      }
    </div>

    <div
      class="flex w-full max-w-[840px] flex-col gap-6 rounded-m border border-border bg-card p-6 md:flex-row md:p-8"
    >
      <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-secondary">
        <Icon name="puzzle" class="h-[26px] w-[26px] text-primary" />
      </div>
      <div class="flex flex-col gap-2">
        <h2 class="font-primary text-lg font-semibold text-foreground">Bring your own game</h2>
        <p class="text-sm leading-relaxed text-muted-foreground">
          Every module — including these sixteen — is just an OCI bundle: a template.yaml describing
          the container, config schema, and capabilities, plus a module.yaml with metadata. If a
          game runs in a container and takes a config file, it can become a Gameplane module.
        </p>
        <a
          class="flex items-center gap-1 font-primary text-[13px] font-medium text-primary hover:underline"
          href={withBase("/docs/module-authoring/")}
        >
          Read the module authoring guide
          <Icon name="arrow-right" class="h-[13px] w-[13px]" />
        </a>
      </div>
    </div>

    <div class="w-full pt-2 md:pt-4">
      <CtaSection />
    </div>
  </section>
</MarketingLayout>
