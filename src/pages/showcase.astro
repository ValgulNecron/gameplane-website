---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import CtaSection from "../components/CtaSection.astro";
import ScreenshotFrame from "../components/ScreenshotFrame.astro";
import SectionHeader from "../components/SectionHeader.astro";
import serversScreenshot from "../assets/screenshots/servers.png";
import consoleScreenshot from "../assets/screenshots/console.png";
import backupsScreenshot from "../assets/screenshots/backups.png";
import dashboardScreenshot from "../assets/screenshots/dashboard.png";
import modulesScreenshot from "../assets/screenshots/modules.png";

const bigShots = [
  {
    address: "app.gameplane.dev/servers",
    src: serversScreenshot,
    alt: "Servers list showing a running Minecraft server",
    title: "Fleet overview",
    caption: "See every server's status, players online, and phase at a glance.",
  },
  {
    address: "app.gameplane.dev/servers/…/console",
    src: consoleScreenshot,
    alt: "Live console streaming RCON output for a running server",
    title: "Live console",
    caption: "Stream stdout/stderr and send RCON commands without leaving the browser.",
  },
];

const smallShots = [
  {
    address: "…/backups",
    src: backupsScreenshot,
    alt: "Backups page",
    title: "One-click backups",
    caption: "Trigger, schedule, and restore restic-backed snapshots.",
  },
  {
    address: "app.gameplane.dev/",
    src: dashboardScreenshot,
    alt: "Fleet dashboard showing cluster health and resources",
    title: "Fleet dashboard",
    caption: "A cluster-wide view of health, capacity, and recent activity.",
  },
  {
    address: "…/modules",
    src: modulesScreenshot,
    alt: "Module catalog with Minecraft, Terraria, and Valheim",
    title: "Module catalog",
    caption: "Browse and install versioned, signed game templates.",
  },
];
---

<MarketingLayout
  title="Showcase — Gameplane"
  description="A closer look at the Gameplane dashboard — fleet overview, live console, backups, and the module catalog."
>
  <section
    class="flex flex-col items-center gap-8 px-6 pb-16 pt-12 md:gap-12 md:px-20 md:pb-24 md:pt-20"
  >
    <SectionHeader
      eyebrow="IN ACTION"
      title="See Gameplane in your browser"
      subtitle="A closer look at the dashboard — from fleet overview to live console."
    />

    <div class="flex w-full max-w-[1280px] flex-col gap-8">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {
          bigShots.map((shot) => (
            <div class="flex flex-col gap-3">
              <ScreenshotFrame
                compact
                address={shot.address}
                src={shot.src}
                alt={shot.alt}
                class="min-h-64 md:min-h-[392px]"
              />
              <div class="flex flex-col gap-1">
                <h2 class="font-primary text-base font-semibold text-foreground">{shot.title}</h2>
                <p class="text-[13px] text-muted-foreground">{shot.caption}</p>
              </div>
            </div>
          ))
        }
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {
          smallShots.map((shot) => (
            <div class="flex flex-col gap-3">
              <ScreenshotFrame
                compact
                address={shot.address}
                src={shot.src}
                alt={shot.alt}
                class="min-h-52 md:min-h-64"
              />
              <div class="flex flex-col gap-1">
                <h2 class="font-primary text-base font-semibold text-foreground">{shot.title}</h2>
                <p class="text-[13px] text-muted-foreground">{shot.caption}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="w-full pt-2 md:pt-4">
      <CtaSection />
    </div>
  </section>
</MarketingLayout>
