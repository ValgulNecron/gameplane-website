---
import BaseLayout from "./BaseLayout.astro";
import Icon from "../components/Icon.astro";
import DocsSidebar from "../components/docs/DocsSidebar.astro";
import DocsPrevNext from "../components/docs/DocsPrevNext.astro";
import { GITHUB_URL } from "../config";
import { withBase } from "../lib/url";

interface Link {
  title: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  /** Breadcrumb leaf; defaults to title. */
  breadcrumb?: string;
  /** Doc id of the current page ("" on the docs home). */
  activeId?: string;
  eyebrow?: string;
  /** Page h1; defaults to title. */
  heading?: string;
  lede?: string;
  prev?: Link | null;
  next?: Link | null;
}

const {
  title,
  description,
  breadcrumb = title,
  activeId = "",
  eyebrow = "DOCUMENTATION",
  heading = title,
  lede,
  prev = null,
  next = null,
} = Astro.props;
---

<BaseLayout title={`${title} — Gameplane docs`} description={description}>
  <div class="flex min-h-screen">
    <aside
      class="sticky top-0 hidden h-screen w-[280px] shrink-0 overflow-y-auto border-r border-sidebar-border bg-sidebar lg:block"
    >
      <DocsSidebar activeId={activeId} />
    </aside>

    <div class="min-w-0 flex-1">
      <div
        class="flex h-16 items-center justify-between border-b border-border px-5 md:px-8"
      >
        <div class="flex items-center gap-3">
          <button
            id="docs-nav-toggle"
            class="text-foreground lg:hidden"
            type="button"
            aria-label="Open docs navigation"
            aria-expanded="false"
            aria-controls="docs-nav-mobile"
          >
            <Icon name="menu" class="h-5 w-5" />
          </button>
          <div class="flex items-center gap-1.5 text-[13px]">
            <a class="text-muted-foreground hover:text-foreground" href={withBase("/docs/")}
              >Docs</a
            >
            {
              breadcrumb !== "Docs" && (
                <>
                  <span class="text-muted-foreground">/</span>
                  <span class="font-medium text-foreground">{breadcrumb}</span>
                </>
              )
            }
          </div>
        </div>
        <a
          class="flex h-9 w-9 items-center justify-center rounded-pill border border-border text-foreground hover:border-muted-foreground"
          href={GITHUB_URL}
          aria-label="GitHub"
        >
          <Icon name="github" class="h-[18px] w-[18px]" />
        </a>
      </div>

      <div id="docs-nav-mobile" class="hidden border-b border-border bg-sidebar lg:!hidden">
        <DocsSidebar activeId={activeId} bare />
      </div>

      <main class="mx-auto flex max-w-[880px] flex-col gap-6 p-5 md:p-8">
        <div class="flex flex-col gap-2">
          <span class="font-primary text-xs font-semibold text-primary">{eyebrow}</span>
          <h1 class="font-primary text-[26px] font-bold text-foreground md:text-[32px]">
            {heading}
          </h1>
          {lede && <p class="max-w-[640px] text-base text-muted-foreground">{lede}</p>}
        </div>
        <slot />
        {(prev || next) && <DocsPrevNext prev={prev} next={next} />}
      </main>
    </div>
  </div>
</BaseLayout>

<script>
  const toggle = document.getElementById("docs-nav-toggle");
  const menu = document.getElementById("docs-nav-mobile");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", open ? "true" : "false");
  });
</script>
