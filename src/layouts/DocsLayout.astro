---
import DocsPrevNext from "../components/docs/DocsPrevNext.astro";
import DocsShell from "./DocsShell.astro";
import { withBase } from "../lib/url";

interface Link {
  title: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  /** Breadcrumb leaf; defaults to title. */
  breadcrumb?: string;
  /** Doc id of the current page ("" on the docs home). */
  activeId?: string;
  eyebrow?: string;
  /** Page h1; defaults to title. */
  heading?: string;
  lede?: string;
  prev?: Link | null;
  next?: Link | null;
}

const {
  title,
  description,
  breadcrumb = title,
  activeId = "",
  eyebrow = "DOCUMENTATION",
  heading = title,
  lede,
  prev = null,
  next = null,
} = Astro.props;

const breadcrumbs = [
  { label: "Docs", href: withBase("/docs/") },
  ...(breadcrumb === "Docs" ? [] : [{ label: breadcrumb }]),
];
---

<DocsShell title={title} description={description} activeId={activeId} breadcrumbs={breadcrumbs}>
  <main class="mx-auto flex w-full max-w-[780px] flex-col gap-6 p-5 lg:p-8">
    <div class="flex flex-col gap-2">
      <span class="font-primary text-[11px] font-semibold tracking-[0.8px] text-primary">{eyebrow}</span>
      <h1 class="font-primary text-[26px] font-bold leading-[1.1] text-foreground lg:text-[30px]">
        {heading}
      </h1>
      {lede && <p class="max-w-[640px] text-[15px] leading-[1.45] text-muted-foreground">{lede}</p>}
    </div>
    <slot />
    {(prev || next) && <DocsPrevNext prev={prev} next={next} />}
  </main>
</DocsShell>
